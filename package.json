{
  "name": "deveyes",
  "displayName": "DevEyes",
  "description": "A smart eye-care reminder for developers.",
  "version": "1.0.0",
  "publisher": "priyanka0920",
  "icon": "media/icon.png",
  "repository": {
  "type": "git",
  "url": "https://github.com/Priyanka0920/DevEyes.git"
},
  "engines": {
    "vscode": "^1.125.0"
  },
  "categories": [
    "Productivity"
  ],
  "keywords": [
  "eye care",
  "reminder",
  "productivity",
  "developer",
  "health",
  "break",
  "coding",
  "wellness"
],
"galleryBanner": {
  "color": "#1E1E2E",
  "theme": "dark"
},
  "activationEvents": [
    "onCommand:deveyes.startReminder",
    "onCommand:deveyes.stopReminder",
    "onCommand:deveyes.openDashboard",
    "onCommand:deveyes.openSettings"
  ],
  "main": "./src/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "deveyes.startReminder",
        "title": "DevEyes: Start Reminder"
      },
      {
        "command": "deveyes.stopReminder",
        "title": "DevEyes: Stop Reminder"
      },
      {
        "command": "deveyes.openDashboard",
        "title": "DevEyes: Open Dashboard"
      },
      {
    "command": "deveyes.openSettings",
    "title": "DevEyes: Open Settings"
      }
      
    ]
  },
  "scripts": {
    "lint": "eslint ."
  },
  "devDependencies": {
    "@types/vscode": "^1.125.0",
    "@types/node": "24.x",
    "eslint": "^9.0.0"
  }
}